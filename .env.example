# ════════════════════════════════════════════════════════════════════════════
# HAPPY HOUR UNLOCKED — Environment Variables
# ════════════════════════════════════════════════════════════════════════════
#
# HOW TO USE:
#   1. Copy this file to .env.local for local development
#   2. Add all variables to Vercel: Settings → Environment Variables
#
# IMPORTANT — Two types of variables:
#
#   REACT_APP_*  → Baked into the browser bundle at build time (public, visible to users)
#                  Only use for non-secret config (Supabase anon key, PostHog key, etc.)
#
#   No prefix    → Server-only, available in Vercel serverless functions at runtime
#                  Use these for secrets that must NEVER reach the browser
#
# ════════════════════════════════════════════════════════════════════════════


# ── SUPABASE (required) ─────────────────────────────────────────────────────
# From: supabase.com → your project → Settings → API
# These are safe to expose in the browser — anon key has RLS applied
REACT_APP_SUPABASE_URL=https://your-project-id.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key-here


# ── GOOGLE PLACES API (two separate vars) ───────────────────────────────────
# From: console.cloud.google.com → APIs & Services → Credentials
#
# Server-only key — used by serverless functions (geocode, places-autocomplete,
# places-details). Set this in Vercel with scope: "Serverless Functions".
# Restrict this key in Google Cloud to your Vercel server IPs.
GOOGLE_PLACES_KEY=your-google-places-api-key-here
#
# Browser key — used if you call Places API directly from the client anywhere.
# Restrict this key in Google Cloud to your domain (happyhourunlocked.com).
REACT_APP_GOOGLE_PLACES_KEY=your-google-places-browser-key-here


# ── ANTHROPIC (server-only — NEVER use REACT_APP_ prefix) ──────────────────
# From: console.anthropic.com → API Keys
# Used by: /api/scan-menu (serverless function only)
# Set in Vercel with scope: "Serverless Functions"
ANTHROPIC_API_KEY=sk-ant-your-key-here


# ── EMAIL (server-only) ─────────────────────────────────────────────────────
# From: resend.com → API Keys
RESEND_API_KEY=re_your-resend-api-key
ADMIN_EMAIL=your-admin-email@example.com


# ── POSTHOG ANALYTICS (optional — free at posthog.com) ─────────────────────
# Without this, analytics events are logged to console only (dev mode)
REACT_APP_POSTHOG_KEY=phc_your_key_here
REACT_APP_POSTHOG_HOST=https://app.posthog.com


# ── MAP TILES (optional — defaults to free OpenStreetMap) ──────────────────
# Leave blank to use OpenStreetMap (free, no key needed)
# For Mapbox (prettier tiles): get token at account.mapbox.com
REACT_APP_MAP_TILE_URL=
REACT_APP_MAP_TILE_ATTRIBUTION=


# ── SITE URL (used in email templates) ─────────────────────────────────────
SITE_URL=https://www.happyhourunlocked.com
